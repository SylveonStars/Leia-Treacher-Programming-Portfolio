                        c_para = doc.add_paragraph(f"{label}. {text}")
                                c_para.paragraph_format.left_indent = Inches(0.5)
                                c_para.runs[0].font.name = 'Times New Roman'
                                c_para.runs[0].font.size = Pt(12)
            
                # Space between questions
                doc.add_paragraph()
                        question_number += 1
                
                # Handle questions without sections
                if questions_without_section:
                    # Check if we need a new page
                    if y_position < margin + 150:
                        c.showPage()
                        y_position = page_height - margin - 50
                    
                    # Section header for questions without sections
                    c.setFont("Times-Bold", 14)
                    section_text = "Additional Questions — Multiple Choice"
                    c.drawString(margin, y_position, section_text)
                    y_position -= 25
                    
                    for vq in questions_without_section:
                        question = vq.question
                        
                        # Check if we need a new page
                        if y_position < margin + 100:
                            c.showPage()
                            y_position = page_height - margin - 50
                        
                        # Add question with marks
                        points = getattr(question, 'points', 1)
                        c.setFont("Times-Bold", 12)
                        question_text = f"{question_number}. {question.prompt} [{points} mark{'s' if points != 1 else ''}]"
                        question_lines = textwrap.wrap(question_text, width=70)
                        for line in question_lines:
                            c.drawString(margin, y_position, line)
                            y_position -= 20
                        
                        # Get choices - use randomized if available
                        if vq.randomized_choices:
                            choices = vq.randomized_choices
                        else:
                            choices = question.choices
                        
                        # Draw choices with proper indentation
                        c.setFont("Times-Roman", 12)
                        if isinstance(choices, dict):
                            for label, text in choices.items():
                                choice_text = f"{label}. {text}"
                                choice_lines = textwrap.wrap(choice_text, width=65)
                                for line in choice_lines:
                                    c.drawString(margin + 20, y_position, line)
                                    y_position -= 18
                        
                        # Space between questions
                        y_position -= 15
                        question_number += 1
            else:
                # No sections - just add questions sequentially
                for idx, vq in enumerate(variant_questions, start=1):
                    question = vq.question
                    points = getattr(question, 'points', 1)
                
                    # Question prompt with marks
                    q_para = doc.add_paragraph()
                    q_run = q_para.add_run(f"{idx}. {question.prompt} [{points} mark{'s' if points != 1 else ''}]")
                    q_run.font.bold = True
                    q_run.font.size = Pt(12)
                    q_run.font.name = 'Times New Roman'
            
                # Get choices - use randomized if available
                if vq.randomized_choices:
                    choices = vq.randomized_choices
                else:
                    choices = question.choices
            
                    # Add choices with proper indentation
                if isinstance(choices, dict):
                    for label, text in choices.items():
                        c_para = doc.add_paragraph(f"{label}. {text}")
                        c_para.paragraph_format.left_indent = Inches(0.5)
                        c_para.runs[0].font.name = 'Times New Roman'
                        c_para.runs[0].font.size = Pt(12)
                # Space between questions
                doc.add_paragraph()
        
            # 6. FOOTER (if provided)
            if hasattr(exam, 'footer_text') and exam.footer_text:
                # Add a page break to ensure footer is on a new page
                doc.add_page_break()
                footer_para = doc.add_paragraph(exam.footer_text)
                footer_para.alignment = WD_PARAGRAPH_ALIGNMENT.CENTER
                footer_para.runs[0].font.italic = True
                footer_para.runs[0].font.size = Pt(10)
                footer_para.runs[0].font.name = 'Times New Roman'
        
            # Save to buffer
            buffer = BytesIO()
            doc.save(buffer)
        
            filename = f"{exam.title}_Variant_{variant.version_label}.docx"
            result_files.append((filename, buffer.getvalue()))
    
        return result_files

    @staticmethod
    def export_variants_to_zip(exam, variant_ids, format_type):
        """
        Export multiple variants to a ZIP file.
        format_type can be 'pdf' or 'docx'
        """
        import zipfile
        from io import BytesIO
    
        buffer = BytesIO()
    
        with zipfile.ZipFile(buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
            if format_type == 'pdf':
                files = ExamExportService.export_variants_to_pdf_files(exam, variant_ids)
            else:  # docx
                files = ExamExportService.export_variants_to_docx_files(exam, variant_ids)
        
            for filename, file_content in files:
                zf.writestr(filename, file_content)
    
        buffer.seek(0)
        return buffer.getvalue()


    @staticmethod
    def export_answer_keys_to_zip(exam, variant_ids):
        """
        Export answer keys for multiple variants to a ZIP file.
        """
        import zipfile
        from io import BytesIO
    
        buffer = BytesIO()
        
        # If variant_ids is None, export all variants
        if variant_ids is None:
            variant_ids = list(exam.variants.values_list('id', flat=True))
    
        with zipfile.ZipFile(buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
            for variant_id in variant_ids:
                variant = exam.variants.get(id=variant_id)
                
                # Generate answer key content
                content = ExamExportService.generate_answer_key_csv(exam, [variant_id])
                filename = f"{exam.title}_Variant_{variant.version_label}_AnswerKey.csv"
                zf.writestr(filename, content.encode('utf-8'))
    
        buffer.seek(0)
        return buffer.getvalue()
    

    @staticmethod
    def export_variants_to_docx(exam, variant_ids):
        """
        Build a .docx containing all specified variants with their questions and choices.
        This returns the raw bytes for a single DOCX file containing all variants.
        """
        from docx import Document
        from docx.shared import Inches
        from io import BytesIO
    
        doc = Document()

        for vid in variant_ids:
            variant = exam.variants.get(id=vid)

            # Heading: Exam Title — Variant X
            doc.add_heading(f"{exam.title} — Variant {variant.version_label}", level=1)

            # Get variant questions in order
            variant_questions = variant.variantquestion_set.select_related('question').order_by('order')

            # Questions
            for idx, vq in enumerate(variant_questions, start=1):
                question = vq.question
            
                # Question prompt, bold
                q_para = doc.add_paragraph()
                run = q_para.add_run(f"{idx}. {question.prompt}")
                run.bold = True

                # Get choices - use randomized if available
                if vq.randomized_choices:
                    choices = vq.randomized_choices
                else:
                    choices = getattr(question, 'choices', {})
            
                # Choices
                if isinstance(choices, dict):
                    for label, text in choices.items():
                        c_para = doc.add_paragraph(f"{label}. {text}")
                        # indent choices
                        c_para.paragraph_format.left_indent = Inches(0.25)

            # Page break between variants (last one will leave an extra blank page, which is fine)
            doc.add_page_break()

        # Serialize to bytes
        buffer = BytesIO()
        doc.save(buffer)
        return buffer.getvalue()

class ExamUpdateService:
    """Service for updating exam settings"""

    @staticmethod
    def update_exam_settings(exam: Exam, settings: Dict[str, Any]) -> Exam:
        """Update exam settings with validation"""
        # Validate settings before updating
        for field, value in settings.items():
            if hasattr(exam, field):
                setattr(exam, field, value)

        # Validate the updated exam
        errors = ExamValidationService.validate_exam_config(exam)
        if errors:
            raise ValidationError("; ".join(errors))

        exam.save()
        return exam

    @staticmethod
    def update_mandatory_questions(exam: Exam, question_ids: List[int]) -> None:
        """Update mandatory questions for an exam"""
        exam.mandatory_questions.set(question_ids)

    @staticmethod
    def update_variant_order(
        exam: Exam, variant_id: int, question_orders: Dict[str, int]
    ) -> None:
        """Update the order of questions in a variant, ignoring missing questions."""
        from .models import Variant, VariantQuestion

        variant = Variant.objects.get(id=variant_id, exam=exam)
        # Only update order for questions that still exist in the variant
        for question_id, order in question_orders.items():
            try:
                vq = VariantQuestion.objects.get(
                    variant=variant, question_id=question_id
                )
                vq.order = order
                vq.save()
            except VariantQuestion.DoesNotExist:
                # Ignore missing questions (e.g., just deleted)
                continue
