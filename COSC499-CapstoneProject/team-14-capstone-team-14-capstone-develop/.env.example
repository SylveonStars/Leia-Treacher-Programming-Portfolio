# =======================
# Example ENV File for ExamVault
# =======================
# Copy this file to `.env` and fill in the values before running the app.

# -----------------------
# DATABASE CONFIGURATION
# -----------------------
POSTGRES_DB=examvault
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------
# DJANGO CONFIGURATION
# -----------------------
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# For production use:
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# -----------------------
# EMAIL CONFIGURATION
# -----------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For real SMTP (example using Gmail)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_email_password

# -----------------------
# FRONTEND CONFIGURATION
# -----------------------
VITE_API_URL=http://localhost/api

# -----------------------
# JWT CONFIGURATION
# -----------------------
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=60      # Minutes
JWT_REFRESH_TOKEN_LIFETIME=1440   # Minutes (1 day)

# -----------------------
# OPTIONAL SECURITY FLAGS
# -----------------------
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
